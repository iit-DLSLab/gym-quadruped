                            <geom name="FR" class="collision" size="0.0265"/>
                        </body>

                    </body>
                </body>
            </body>

            <!-- RL leg -->
            <body name="RL_hip" pos="-0.2399 0.051 0">
                <inertial pos="0.022191 0.015144 -1.5e-05" quat="0.0117635 0.707151 -0.0135493 0.706835" mass="1.993"
                          diaginertia="0.00558695 0.00491009 0.00290132"/>
                <joint name="RL_hip_joint" pos="0 0 0" axis="1 0 0" limited="true" range="-1.22173 1.22173" armature="0.0097" frictionloss="0.3773" damping="0.1832"/>

                <!-- RL_hip visual mesh and collision -->
                <geom type="mesh" class="visual" quat="0 0 1 0" rgba="0.2 0.2 0.2 1" mesh="hip"/>
                <geom type="capsule" class="collision" size="0.046 0.0209" pos="0 0.083 0"
                      quat="0.707107 0.707107 0 0"/>

                <body name="RL_thigh" pos="0 0.083 0">
