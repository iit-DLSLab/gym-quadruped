<mujoco model="aliengo_description">
    <compiler angle="radian" autolimits="true"/>

    <default>
        <default class="visual">
            <geom type="mesh" contype="0" conaffinity="0" group="2"/>
        </default>
        <default class="collision">
            <geom group="3" rgba="0.2 0.2 0.2 0.5"/>
        </default>

        <default class="hip">
            <motor ctrlrange="-35.278 35.278"/>
        </default>
        <default class="thigh">
            <motor ctrlrange="-35.278 35.278"/>
        </default>
        <default class="calf">
            <motor ctrlrange="-44.4 44.4"/>
        </default>

    </default>

    <asset>
        <mesh name="base" file="assets/base.stl"/>
        <mesh name="hip" file="assets/hip.stl"/>
        <mesh name="thigh_mirror" file="assets/thigh_mirror.stl"/>
        <mesh name="calf" file="assets/calf.stl"/>
        <mesh name="thigh" file="assets/thigh.stl"/>
    </asset>


    <worldbody>

        <body name="base" pos="0 0 0.4">
            <inertial pos="0.00846406 0.00404455 -0.000762916" quat="-3.12625e-05 0.708321 0.00247254 0.705886"
                      mass="13.042" diaginertia="0.174706 0.161175 0.033357"/>
            <freejoint/>

            <!-- base visual mesh and collision -->
            <geom type="mesh" class="visual" rgba="0.2 0.2 0.2 1" mesh="base"/>
            <geom type="box" class="collision" size="0.18 0.075 0.056"/>

            <!-- modify this to add payload -->
            <!--body name="payload" pos="0 0 0">
                <geom type="box" mass="0.01" pos="0 0 0.1" size="0.05 0.05 0.05" rgba="1 0 0 0.3"/>
            </body-->

            <!-- imu and camera -->
            <site name="imu" pos="0 0 0"/>
            <camera name="robotcam" pos="0.31 -0.005 0.00292751" quat="0.4 0.4 -0.4 -0.4"/>

            <!-- FL leg -->
            <body name="FL_hip" pos="0.2399 0.051 0">
                <inertial pos="-0.022191 0.015144 -1.5e-05" quat="-0.0135493 0.706835 0.0117635 0.707151" mass="1.993"
                          diaginertia="0.00558695 0.00491009 0.00290132"/>
                <joint name="FL_hip_joint" pos="0 0 0" axis="1 0 0" limited="true" range="-1.22173 1.22173" armature="0.0062" frictionloss="0.4168" damping="0.1744"/>

                <!-- FL_hip visual mesh and collision -->
                <geom type="mesh" class="visual" rgba="0.2 0.2 0.2 1" mesh="hip"/>
                <geom type="capsule" class="collision" size="0.046 0.0209" pos="0 0.083 0"
                      quat="0.707107 0.707107 0 0"/>

                <body name="FL_thigh" pos="0 0.083 0">
                    <inertial pos="-0.005607 -0.003877 -0.048199" quat="0.717987 -0.031246 -0.0335669 0.694544"
                              mass="0.639" diaginertia="0.0058474 0.00571186 0.000324584"/>
                    <joint name="FL_thigh_joint" pos="0 0 0" axis="0 1 0" armature="0.0172" frictionloss="0.3451" damping="0.1396"/>

                    <!-- FL_thigh visual mesh and collision -->
                    <geom type="mesh" class="visual" rgba="0.2 0.2 0.2 1" mesh="thigh"/>
                    <geom type="box" class="collision" size="0.125 0.0187 0.0215" pos="0 0 -0.125"
                          quat="0.707107 0 0.707107 0"/>

                    <body name="FL_calf" pos="0 0 -0.25">
                        <inertial pos="0.00215606 4.88427e-05 -0.166671" quat="0.707462 0.00517582 0.00535172 0.706712"
