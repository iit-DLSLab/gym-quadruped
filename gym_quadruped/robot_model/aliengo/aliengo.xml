                        <!-- FL_calf visual mesh and collision -->
                        <geom type="mesh" class="visual" rgba="0 0 0 1" mesh="calf"/>
                        <geom type="box" class="collision" size="0.125 0.0104 0.008" pos="0 0 -0.125"
                              quat="0.707107 0 0.707107 0"/>

                        <!-- FL_foot only collision -->
                        <!--geom name="FL" class="collision" size="0.0265" pos="0 0 -0.25"/-->

                        <body name="FL_foot" pos="0 0 -0.25">
                            <!-- FL_foot only collision -->
                            <geom name="FL" class="collision" size="0.0265"/>
                        </body>

                    </body>
                </body>
            </body>

            <!-- FR leg -->
            <body name="FR_hip" pos="0.2399 -0.051 0">
                <inertial pos="-0.022191 -0.015144 -1.5e-05" quat="0.0135493 0.706835 -0.0117635 0.707151" mass="1.993"
