                        <joint name="RL_calf_joint" pos="0 0 0" axis="0 1 0" limited="true" range="-2.77507 -0.645772" armature="0.0233" frictionloss="0.3549" damping="0.2531"/>

                        <!-- RL_calf visual mesh and collision -->
                        <geom type="mesh" class="visual" rgba="0 0 0 1" mesh="calf"/>
                        <geom type="box" class="collision" size="0.125 0.0104 0.008" pos="0 0 -0.125"
                              quat="0.707107 0 0.707107 0"/>

                        <!-- RL_foot only collision -->
                        <!--geom name="RL" class="collision" size="0.0265" pos="0 0 -0.25"/-->
                        
                        <body name="RL_foot" pos="0 0 -0.25">
                            <!-- RL_foot only collision -->
                            <geom name="RL" class="collision" size="0.0265"/>
                        </body>

                    </body>
                </body>
            </body>

            <!-- RR leg -->
            <body name="RR_hip" pos="-0.2399 -0.051 0">
                <inertial pos="0.022191 -0.015144 -1.5e-05" quat="-0.0117635 0.707151 0.0135493 0.706835" mass="1.993"
                          diaginertia="0.00558695 0.00491009 0.00290132"/>
                <joint name="RR_hip_joint" pos="0 0 0" axis="1 0 0" limited="true" range="-1.22173 1.22173" armature="0.0119" frictionloss="0.6511" damping="0.2535"/>

