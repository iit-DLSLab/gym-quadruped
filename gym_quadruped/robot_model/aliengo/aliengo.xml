    <keyframe>
        <key name="home" qpos="0 0 0.35 1 0 0 0 0 0.9 -1.8 0 0.9 -1.8 0 0.9 -1.8 0 0.9 -1.8"/>
        <key name="down" qpos="0 0 0.05 1 0 0 0 0.0 1.21 -2.794 0.0 1.21 -2.794 0.0 1.21 -2.794 0.0 1.21 -2.794"/>
    </keyframe>
</mujoco>
