                            <geom name="RR" class="collision" size="0.0265"/>
                        </body>

                    </body>
                </body>
            </body>
        </body>
    </worldbody>

    <actuator>       
        <motor name="FL_hip"   class="hip"    gear="1" joint="FL_hip_joint"/>
        <motor name="FL_thigh" class="thigh"  gear="1" joint="FL_thigh_joint"/>
        <motor name="FL_calf"  class="calf"   gear="1" joint="FL_calf_joint"/>
        <motor name="FR_hip"   class="hip"    gear="1" joint="FR_hip_joint"/>
        <motor name="FR_thigh" class="thigh"  gear="1" joint="FR_thigh_joint"/>
        <motor name="FR_calf"  class="calf"   gear="1" joint="FR_calf_joint"/>
        <motor name="RL_hip"   class="hip"    gear="1" joint="RL_hip_joint"/>
        <motor name="RL_thigh" class="thigh"  gear="1" joint="RL_thigh_joint"/>
        <motor name="RL_calf"  class="calf"   gear="1" joint="RL_calf_joint"/>
        <motor name="RR_hip"   class="hip"    gear="1" joint="RR_hip_joint"/>
        <motor name="RR_thigh" class="thigh"  gear="1" joint="RR_thigh_joint"/>
        <motor name="RR_calf"  class="calf"   gear="1" joint="RR_calf_joint" />
    </actuator>

    <sensor>
        <accelerometer name="imu_acc" site="imu"/>
        <gyro name="imu_gyro" site="imu"/>
        <framepos name="imu_pos" objtype="site" objname="imu"/>
        <framequat name="imu_quat" objtype="site" objname="imu"/>

        <jointpos name="FL_hip_joint_pos" joint="FL_hip_joint"/>
        <jointpos name="FL_thigh_joint_pos" joint="FL_thigh_joint"/>
        <jointpos name="FL_calf_joint_pos" joint="FL_calf_joint"/>
        <jointpos name="FR_hip_joint_pos" joint="FR_hip_joint"/>
        <jointpos name="FR_thigh_joint_pos" joint="FR_thigh_joint"/>
        <jointpos name="FR_calf_joint_pos" joint="FR_calf_joint"/>
        <jointpos name="RL_hip_joint_pos" joint="RL_hip_joint"/>
        <jointpos name="RL_thigh_joint_pos" joint="RL_thigh_joint"/>
        <jointpos name="RL_calf_joint_pos" joint="RL_calf_joint"/>
        <jointpos name="RR_hip_joint_pos" joint="RR_hip_joint"/>
        <jointpos name="RR_thigh_joint_pos" joint="RR_thigh_joint"/>
        <jointpos name="RR_calf_joint_pos" joint="RR_calf_joint"/>
